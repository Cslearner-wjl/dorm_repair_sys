<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dorm.repair.mapper.RepairFeedbackMapper">

  <resultMap id="RepairFeedbackVOResultMap" type="com.dorm.repair.vo.RepairFeedbackVO">
    <result column="score" property="score"/>
    <result column="comment" property="comment"/>
    <result column="created_at" property="createdAt"/>
  </resultMap>

  <insert id="insert" parameterType="com.dorm.repair.entity.RepairFeedback"
          useGeneratedKeys="true" keyProperty="id">
    INSERT INTO repair_feedbacks (
      order_id, student_id, score, comment
    ) VALUES (
      #{orderId}, #{studentId}, #{score}, #{comment}
    )
  </insert>

  <select id="findByOrderId" resultMap="RepairFeedbackVOResultMap">
    SELECT score, comment, created_at
    FROM repair_feedbacks
    WHERE order_id = #{orderId}
    LIMIT 1
  </select>
</mapper>
